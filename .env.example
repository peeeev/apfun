# apfun environment configuration. Copy to .env and edit for local use.
# All variables use the APFUN_ prefix. Real secrets do NOT belong in this file.

# HTTP binding. Do not set to 127.0.0.1 — Apache reverse-proxies to 0.0.0.0:4000.
APFUN_HOST=0.0.0.0
APFUN_PORT=4000

# Database
APFUN_DB_URL=sqlite:///data/apfun.db

# Anthropic API key — required for any LLM call (task 004 wrapper).
APFUN_ANTHROPIC_API_KEY=

# Reddit — residential proxy (datacenter IPs are network-blocked). Browser-
# mimicking UAs are handled internally; no username/credentials needed.
# Pick a provider (Webshare/IPRoyal/…) — see docs/operator/SETUP.md.
APFUN_REDDIT_HTTP_PROXY=http://username:password@p.webshare.io:80

# Additional keys (DataForSEO, Resend …) land here as their tasks add them.
